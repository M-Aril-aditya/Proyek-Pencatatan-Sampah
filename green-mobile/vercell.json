{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    
    { "src": "/_expo/static/(.*)", "dest": "/_expo/static/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/static/(.*)", "dest": "/static/$1" },

    
    { "src": "/(.*\\.ttf)$", "dest": "/_expo/static/fonts/$1" },
    { "src": "/(.*\\.woff2)$", "dest": "/_expo/static/fonts/$1" },

    
    { "src": "/(.*\\.(?:js|css|map|png|jpg|jpeg|svg|json|ico|wasm|woff2|ttf))$", "dest": "/$1" },

    
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
